# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Build outputs (Render builds these on the server)
client/dist/
server/dist/

# Environment files — NEVER commit these
.env
server/.env
client/.env.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Uploaded files — stored on Render's persistent disk
server/uploads/*
!server/uploads/.gitkeep

# SSL certs (dev only)
certs/
